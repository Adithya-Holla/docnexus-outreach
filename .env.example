# .env.example — copy to .env.local and fill in your values.
# Never commit real secrets to this file.

# ── Database (Neon PostgreSQL) ─────────────────────────────────────────────────
# Pooled connection — used by the app at runtime (get from Neon dashboard)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require"

# Direct (non-pooled) connection — used by Prisma migrate only
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# ── Auth ───────────────────────────────────────────────────────────────────────
# Strong random string (32+ chars). Generate one:  openssl rand -base64 32
JWT_SECRET="replace-with-a-strong-random-secret"

# ── Cron ───────────────────────────────────────────────────────────────────────
# Vercel Cron uses this to authenticate calls to /api/cron/send-followups.
# Set the same value in your Vercel project environment variables.
CRON_SECRET="replace-with-a-random-secret"

# ── AI ─────────────────────────────────────────────────────────────────────────
# OpenRouter API key — get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-..."

# ── Email sending (Resend) ──────────────────────────────────────────────────────
# Sign up at https://resend.com — free tier: 3,000 emails/month, 100/day
# Leave blank to run in simulation mode (emails logged to console, not sent)
RESEND_API_KEY="re_..."

# Verified "From" address in your Resend dashboard.
# The logged-in user's name is the display name; their email becomes Reply-To.
RESEND_FROM_EMAIL="onboarding@resend.dev"

# Public URL of this deployment — embedded in email tracking-pixel URLs.
# Example: "https://docnexus.yourdomain.com"  (no trailing slash)
APP_BASE_URL="http://localhost:3000"
