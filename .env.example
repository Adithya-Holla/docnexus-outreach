# .env.example

# Database — SQLite file path
DATABASE_URL="file:./dev.db"

# OpenRouter API key — get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY="your_openrouter_api_key"

# JWT secret — use a strong random string in production (32+ chars)
JWT_SECRET="cI8HJe9mKNoKrPdE7l2dm9s3qwjKOq5Pj0WH7xhlCyV"

# ── Email sending (Resend) ──────────────────────────────────────────────────────
# Sign up at https://resend.com — free tier: 3,000 emails/month, 100/day
# Leave blank to run in simulation mode (emails logged to console, not sent)
RESEND_API_KEY="re_ertyAho9_DQzpUCixpprPA9KnWY18LKHt"

# The "From" address on a domain you have verified in the Resend dashboard.
# The logged-in user's name is the display name; their email becomes Reply-To.
# Example: "outreach@yourdomain.com"
RESEND_FROM_EMAIL=""

# Public URL of this deployment — embedded in tracking pixel URLs inside emails.
# Example: "https://docnexus.yourdomain.com"  (no trailing slash)
APP_BASE_URL="http://localhost:3000"
