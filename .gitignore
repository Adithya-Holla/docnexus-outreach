# .gitignore

# Dependencies
node_modules/
/.pnp
.pnp.js

# Next.js build output
/.next/
/out/

# Production build
/build

# Environment variables — never commit secrets
.env
.env.local

# Database file — contains seed data, not versioned
prisma/dev.db
prisma/dev.db-journal

# TypeScript
*.tsbuildinfo
next-env.d.ts

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

