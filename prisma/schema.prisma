// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Platform user — pharma/MSL/device rep who logs in and creates campaigns.
/// Password is bcrypt-hashed (cost factor 12). Role drives AI prompt framing.
model User {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  email     String   @unique
  password  String
  company   String
  /// pharma_marketing_manager | msl | medical_device_rep | other
  role      String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

/// Represents a licensed healthcare professional (HCP) in the system.
/// Physicians are read-only seed data — created via seed script, never via UI.
/// Indexed on all filterable fields used in the Physician Discovery module.
model Physician {
  id                  String   @id @default(uuid())
  /// National Provider Identifier — 10-digit unique identifier assigned by CMS
  npi                 String   @unique
  firstName           String
  lastName            String
  specialty           String
  subSpecialty        String?
  affiliation         String
  city                String
  state               String
  email               String   @unique
  /// Year the physician registered their NPI — used for "years of experience" filter
  npiRegistrationYear Int
  acceptingPatients   Boolean  @default(true)
  boardCertified      Boolean  @default(true)
  createdAt           DateTime @default(now())

  enrollments CampaignEnrollment[]

  @@index([specialty])
  @@index([state])
  @@index([affiliation])
  @@index([npiRegistrationYear])
}

/// An outreach campaign targeting a set of physicians with a multi-step email sequence.
/// Status lifecycle: draft → active → completed
/// type is stored as a string (SQLite has no native enum) and validated at the API layer via Zod.
model Campaign {
  id        String   @id @default(uuid())
  name      String
  /// cold_outbound | reengagement | conference_followup
  type      String
  /// draft | active | completed
  status    String   @default("draft")
  /// User who created this campaign — null for campaigns created before auth was added
  userId    String?
  createdAt DateTime @default(now())
  /// Auto-managed by Prisma — useful for "last updated" display in the dashboard
  updatedAt DateTime @updatedAt

  sequences   SequenceStep[]
  enrollments CampaignEnrollment[]
  dispatches  EmailDispatch[]
  events      EmailEvent[]
}

/// A single email step within a campaign's outreach sequence.
/// Templates use {{variable}} syntax resolved by the templateEngine at send time.
/// Cascade delete ensures no orphaned steps when a campaign is removed.
model SequenceStep {
  id              String @id @default(uuid())
  stepNumber      Int
  /// Days after the previous step to send this email (0 = send immediately)
  delayDays       Int    @default(0)
  subjectTemplate String
  bodyTemplate    String
  campaignId      String

  campaign   Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  dispatches EmailDispatch[]

  @@index([campaignId])
}

/// Join table tracking which physicians are enrolled in which campaigns.
/// status reflects the current outreach state for a given physician in a given campaign.
/// Status is auto-derived from EmailEvents — the UI and webhooks write events,
/// and the analytics layer computes the effective status.
/// The @@unique constraint prevents enrolling the same physician in a campaign twice.
model CampaignEnrollment {
  id          String   @id @default(uuid())
  campaignId  String
  physicianId String
  /// pending | contacted | opened | replied | bounced | meeting_booked
  status      String   @default("contacted")
  enrolledAt  DateTime @default(now())

  campaign   Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  physician  Physician       @relation(fields: [physicianId], references: [id])
  dispatches EmailDispatch[]
  events     EmailEvent[]

  @@unique([campaignId, physicianId])
  @@index([campaignId])
  @@index([physicianId])
}

/// One record per email sent to a physician for a specific sequence step.
/// Created atomically when the campaign is launched (or when a scheduled step fires).
model EmailDispatch {
  id                String   @id @default(uuid())
  campaignId        String
  physicianId       String
  enrollmentId      String
  sequenceStepId    String
  sentAt            DateTime @default(now())
  /// Message-ID from email provider (SendGrid, Resend, etc.) for webhook correlation
  providerMessageId String?

  campaign     Campaign           @relation(fields: [campaignId],    references: [id], onDelete: Cascade)
  enrollment   CampaignEnrollment @relation(fields: [enrollmentId],  references: [id], onDelete: Cascade)
  sequenceStep SequenceStep       @relation(fields: [sequenceStepId], references: [id], onDelete: Cascade)
  events       EmailEvent[]

  @@index([campaignId])
  @@index([enrollmentId])
  @@index([sentAt])
}

/// Immutable audit log of every email-lifecycle event.
/// dispatchId is nullable so manually recorded events (e.g. MEETING_BOOKED via UI)
/// don't need to be tied to a specific dispatch.
/// providerEventId ensures webhook replays are idempotent.
model EmailEvent {
  id              String   @id @default(uuid())
  dispatchId      String?
  campaignId      String
  physicianId     String
  enrollmentId    String
  /// SENT | DELIVERED | OPENED | REPLIED | BOUNCED | MEETING_BOOKED
  eventType       String
  timestamp       DateTime @default(now())
  /// Arbitrary JSON string (e.g. provider metadata, user-agent, IP)
  metadata        String?
  /// Unique ID from the email provider — prevents duplicate webhook events
  providerEventId String?  @unique

  dispatch   EmailDispatch?     @relation(fields: [dispatchId],  references: [id], onDelete: Cascade)
  campaign   Campaign           @relation(fields: [campaignId],  references: [id], onDelete: Cascade)
  enrollment CampaignEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([enrollmentId])
  @@index([dispatchId])
  @@index([eventType])
  @@index([timestamp])
}
